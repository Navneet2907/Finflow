{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "merchant": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["Completed", "Pending", "Failed"] },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "merchant", "category", "amount", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public profile details for a user"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction history for a specific user"
    }
  }
}
