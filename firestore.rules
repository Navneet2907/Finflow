rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Rules ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
      
      function isValidUser(data) {
        return data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 100 &&
               (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
               (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500));
      }

      // --- Transaction Rules ---
      match /transactions/{transactionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransaction(incoming());
        allow update: if isOwner(userId) && isValidTransaction(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['merchant', 'category', 'amount', 'status', 'date', 'time', 'paymentMethod']);
        allow delete: if isOwner(userId);

        function isValidTransaction(data) {
          return data.userId == userId &&
                 data.id is string && data.id.size() <= 128 &&
                 data.merchant is string && data.merchant.size() <= 100 &&
                 data.category is string && data.category.size() <= 50 &&
                 data.amount is number && data.amount >= 0 &&
                 data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
                 (data.status == null || data.status in ['Completed', 'Pending', 'Failed']);
        }
      }
    }
  }
}
